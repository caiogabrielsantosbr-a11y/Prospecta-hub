# Database
DATABASE_URL=sqlite+aiosqlite:///./data/prospect.db

# SMTP Config (for email dispatch)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# App Config
# CORS_ORIGINS: Comma-separated list of allowed origins for CORS policy
# This controls which frontend URLs can make requests to the backend
# Examples:
#   - Local development only: http://localhost:5173
#   - Local + Vercel production: http://localhost:5173,https://your-app.vercel.app
#   - Multiple environments: http://localhost:5173,https://your-app.vercel.app,https://staging.vercel.app
#   - With tunnel services: http://localhost:5173,https://abc123.ngrok.io,https://your-app.vercel.app
CORS_ORIGINS=http://localhost:5173,https://your-app.vercel.app

# Supabase Configuration
# Get these values from your Supabase project settings
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key-here
