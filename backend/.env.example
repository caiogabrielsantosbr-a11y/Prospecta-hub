# Database
DATABASE_URL=sqlite+aiosqlite:///./data/prospect.db

# SMTP Config (for email dispatch)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# App Config
# CORS_ORIGINS: Comma-separated list of allowed origins for CORS policy
# This controls which frontend URLs can make requests to the backend
# Examples:
#   - Local development only: http://localhost:5173
#   - Local + Vercel production: http://localhost:5173,https://your-app.vercel.app
#   - Multiple environments: http://localhost:5173,https://your-app.vercel.app,https://staging.vercel.app
#   - With tunnel services: http://localhost:5173,https://abc123.ngrok.io,https://your-app.vercel.app
CORS_ORIGINS=http://localhost:5173,https://your-app.vercel.app

# Supabase Configuration
# Get these values from your Supabase project settings (Settings > API)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key-here
SUPABASE_SERVICE_KEY=your-service-role-key-here
SUPABASE_JWT_SECRET=your-jwt-secret-here

# Gmail OAuth2 (Google Cloud Console → APIs → Credenciais → OAuth 2.0)
# Passo a passo: console.cloud.google.com → Ativar Gmail API → Criar credencial Web → copiar abaixo
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=http://localhost:8000/api/gmail/callback

# Gemini AI (classificação de emails — gratuito)
# Obter em: aistudio.google.com/app/apikey
GEMINI_API_KEY=
